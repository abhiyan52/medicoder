# Path to the GCP service account key.
# For normal operations: set this to your local key path.
# For Docker: this should remain the local path — Docker overrides it to /app/credentials/gcp-key.json internally.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp-key.json

# Required for Docker only: host path to your GCP service account key.
# Docker Compose mounts this file into the container.
#   export GCP_KEY_PATH=/path/to/your/gcp-key.json
#   docker compose up
GCP_KEY_PATH=/path/to/your/gcp-key.json

# Optional overrides (defaults shown):
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# API server settings (defaults shown)
# API_HOST=0.0.0.0
# API_PORT=8000
# CORS_ORIGINS=http://localhost:5173

# Output directory for processed notes (relative to project root)
# OUTPUT_DIR=output
